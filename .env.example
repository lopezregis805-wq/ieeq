# ============================================================
# .env.example — plantilla de configuración local
#
# Copia este archivo a ".env" (o defínelas como SetEnv en tu
# VirtualHost de Apache) y pon AHÍ tus valores reales.
# El archivo ".env" está en .gitignore: nunca se sube al repo.
# ============================================================

IEEQ_DB_HOST=localhost
IEEQ_DB_NAME=ieeq_registro
IEEQ_DB_USER=ieeq_app
IEEQ_DB_PASS=cambia_esto_por_tu_password_local
